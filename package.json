{
  "name": "jobwebsite",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "frontend": "npm run dev --prefix frontend",
    "backend": "nodemon backend/index.js",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "npm install --prefix frontend && npm run build --prefix frontend",
    "start": "node backend/index.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "datauri": "^4.1.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "multer": "^2.2.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.3",
    "nodemon": "^3.1.14"
  }
}
